# Senha do banco — troque por uma senha forte (ex.: openssl rand -hex 24)
POSTGRES_PASSWORD=troque_esta_senha

# Chave da Evolution API — gere uma: openssl rand -hex 24
EVOLUTION_API_KEY=troque_esta_chave

# Sua chave da Anthropic (console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Modelo de IA
AI_MODEL=claude-haiku-4-5
