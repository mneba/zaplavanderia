// Schema do ZapLavanderia — Fase 3

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plano {
  TRIAL
  STARTER
  PRO
  EXPIRADO
}

model Lavanderia {
  id             String    @id @default(cuid())
  slug           String    @unique
  nome           String
  donoFone       String    @default("")
  ativa          Boolean   @default(true)
  plano          Plano     @default(TRIAL)
  trialExpiraEm  DateTime?
  config         Json      @default("{}")
  criadaEm       DateTime  @default(now())

  conversas Conversa[]
  usuarios  Usuario[]
  midias    MidiaResposta[]
}

model Usuario {
  id           String     @id @default(cuid())
  email        String     @unique
  senhaHash    String
  nome         String
  lavanderiaId String
  lavanderia   Lavanderia @relation(fields: [lavanderiaId], references: [id])
  criadoEm     DateTime   @default(now())
}

enum StatusConversa {
  BOT
  HUMANO
}

model Conversa {
  id           String         @id @default(cuid())
  lavanderiaId String
  lavanderia   Lavanderia     @relation(fields: [lavanderiaId], references: [id])
  clienteJid   String
  clienteNome  String         @default("Cliente")
  status       StatusConversa @default(BOT)
  primeiraMsg  Boolean        @default(true)
  botResetadoEm DateTime?
  criadaEm     DateTime       @default(now())
  atualizadaEm DateTime       @updatedAt

  mensagens Mensagem[]

  @@unique([lavanderiaId, clienteJid])
  @@index([lavanderiaId, atualizadaEm])
}

enum AutorMensagem {
  CLIENTE
  BOT
  DONO
}

model Mensagem {
  id         String        @id @default(cuid())
  conversaId String
  conversa   Conversa      @relation(fields: [conversaId], references: [id])
  autor      AutorMensagem
  texto      String
  criadaEm   DateTime      @default(now())

  @@index([conversaId, criadaEm])
}

model MidiaResposta {
  id            String     @id @default(cuid())
  lavanderiaId  String
  lavanderia    Lavanderia @relation(fields: [lavanderiaId], references: [id], onDelete: Cascade)
  nome          String
  tipo          String
  arquivo       String
  quandoEnviar  String
  legenda       String?
  ativa         Boolean    @default(true)
  criadaEm      DateTime   @default(now())

  @@index([lavanderiaId])
}
